CARTESIA_API_KEY=

# === Pronunciation Assessment ===
ELSA_API_KEY=

# === Premium S2S ===
HUME_API_KEY=
OPENAI_API_KEY=

# === LiveKit ===
LIVEKIT_URL=
LIVEKIT_API_KEY=
