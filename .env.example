# === Mock Flags (set to false when real services are ready) ===
USE_MOCK_LLM=true
USE_MOCK_TTS=true
USE_MOCK_STT=true
USE_MOCK_LIVEKIT=true

# === JWT ===
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# === LLM (OpenRouter / SiliconFlow) ===
OPENROUTER_API_KEY=
